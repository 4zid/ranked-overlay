{
  "name": "ranked-overlay",
  "version": "1.0.0",
  "description": "Valorant ranked overlay - muestra rango, RR y modo de juego",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win",
    "build:portable": "electron-builder --win portable"
  },
  "author": "Lautaro",
  "license": "ISC",
  "build": {
    "appId": "com.lautaro.ranked-overlay",
    "productName": "Ranked Overlay",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "preload-control.js",
      "src/**/*",
      "assets/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.png",
      "signAndEditExecutable": false
    },
    "portable": {
      "artifactName": "RankedOverlay.exe"
    }
  },
  "devDependencies": {
    "electron": "^40.6.1",
    "electron-builder": "^26.8.1"
  }
}
